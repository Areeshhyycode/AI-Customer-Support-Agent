# =============================================================
# REQUIRED
# =============================================================

# MongoDB Atlas connection string (with username, password, and database name)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB=ai_support

# Groq API key (https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# Groq model to use for chat completions
GROQ_MODEL=llama-3.3-70b-versatile

# Confidence threshold (0-1). If top vector match score is below this, suggest human handoff.
RAG_CONFIDENCE_THRESHOLD=0.55

# Embeddings: set HF_TOKEN to use the Hugging Face Inference API (fast, no
# model download — recommended for Vercel). Leave it empty to use the local
# Xenova model instead. Get a free token at https://huggingface.co/settings/tokens
HF_TOKEN=

# =============================================================
# VECTOR DATABASE — choose ONE
# =============================================================

# Which vector store to use: "mongodb" (default) or "pinecone"
VECTOR_DB=mongodb

# --- Only needed if VECTOR_DB=pinecone ---
PINECONE_API_KEY=pcsk_your_key_here
PINECONE_INDEX_NAME=ai-support

# =============================================================
# AUTHENTICATION (admin login)
# =============================================================

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=replace_with_random_32_byte_base64_string

# Your deployed URL (use http://localhost:3001 locally, your Vercel URL in production)
NEXTAUTH_URL=http://localhost:3001

# Admin login credentials
ADMIN_EMAIL=admin@example.com
# Generate with: node -e "require('bcryptjs').hash('your-password', 10).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$10$replace_with_bcrypt_hash
